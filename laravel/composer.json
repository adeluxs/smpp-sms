{
    "name": "smpp-platform/laravel",
    "description": "SMPP Platform Control Plane",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/telescope": "^5.0",
        "spatie/laravel-activitylog": "^4.0",
        "spatie/laravel-permission": "^6.0",
        "laravel/fortify": "^1.0",
        "laravel/breeze": "^1.0",
        "predis/predis": "^2.0",
        "vlucas/phpdotenv": "^5.6",
        "nesbot/carbon": "^3.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^11.0",
        "nunomaduro/collision": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-dev": true,
            "php-http/discovery": true,
            "php-http/guzzle6-adapter": true,
            "ralouphie/getidiomatic": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}